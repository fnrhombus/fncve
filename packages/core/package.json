{
  "name": "fncve",
  "version": "0.1.0",
  "description": "MCP server for CVE and vulnerability lookup. Check dependencies against OSV.dev from Claude Code, Cursor, etc.",
  "keywords": [
    "mcp",
    "cve",
    "vulnerability",
    "security",
    "osv",
    "npm-audit",
    "claude-code",
    "cursor"
  ],
  "license": "MIT",
  "author": "fnrhombus",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnrhombus/fncve"
  },
  "bugs": {
    "url": "https://github.com/fnrhombus/fncve/issues"
  },
  "homepage": "https://github.com/fnrhombus/fncve#readme",
  "type": "module",
  "bin": {
    "fncve": "./dist/index.js"
  },
  "exports": {
    ".": "./src/index.ts",
    "./osv": "./src/osv.ts",
    "./parsers": "./src/parsers.ts"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  }
}
